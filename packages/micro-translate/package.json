{
  "name": "@jack3898/micro-translate",
  "description": "A tiny TypeScript-first translation utility.",
  "version": "0.3.0",
  "author": "Jack Wright",
  "license": "Apache-2.0",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "nx": {
    "sourceRoot": "{projectRoot}/src",
    "projectType": "library",
    "targets": {
      "build": {
        "defaultConfiguration": "build"
      },
      "prepack": {
        "defaultConfiguration": "build"
      },
      "dev": {
        "defaultConfiguration": "dev"
      },
      "type-check": {
        "defaultConfiguration": "type-check"
      },
      "publish": {
        "defaultConfiguration": "publish"
      }
    }
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./intl/num": {
      "types": "./dist/intl/num.d.ts",
      "import": "./dist/intl/num.js"
    },
    "./intl/plural": {
      "types": "./dist/intl/plural.d.ts",
      "import": "./dist/intl/plural.js"
    },
    "./intl/date": {
      "types": "./dist/intl/date.d.ts",
      "import": "./dist/intl/date.js"
    },
    "./intl/list": {
      "types": "./dist/intl/list.d.ts",
      "import": "./dist/intl/list.js"
    },
    "./intl/relative-time": {
      "types": "./dist/intl/relative-time.d.ts",
      "import": "./dist/intl/relative-time.js"
    }
  },
  "devDependencies": {
    "expect-type": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  },
  "files": [
    "./dist",
    "./LICENSE",
    "./README.md"
  ],
  "keywords": [
    "esm",
    "i18n",
    "internationalization",
    "interpolation",
    "l10n",
    "locale",
    "localization",
    "tiny",
    "translate",
    "translation",
    "type-safe",
    "utility",
    "vanilla"
  ],
  "repository": "jack3898/jwtools.git",
  "types": "./dist/index.d.ts"
}
