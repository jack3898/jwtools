{
  "name": "@jack3898/micro-translate",
  "description": "A tiny TypeScript-first translation utility.",
  "version": "0.1.4",
  "author": "Jack Wright",
  "license": "Apache-2.0",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "nx": {
    "sourceRoot": "{projectRoot}/src",
    "projectType": "library",
    "targets": {
      "build": {
        "defaultConfiguration": "build"
      },
      "prepack": {
        "defaultConfiguration": "build"
      },
      "dev": {
        "defaultConfiguration": "dev"
      },
      "type-check": {
        "defaultConfiguration": "type-check"
      },
      "publish": {
        "defaultConfiguration": "publish"
      }
    }
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "devDependencies": {
    "expect-type": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  },
  "files": [
    "./dist",
    "./LICENSE",
    "./README.md"
  ],
  "keywords": [
    "esm",
    "i18n",
    "internationalization",
    "interpolation",
    "l10n",
    "locale",
    "localization",
    "tiny",
    "translate",
    "translation",
    "type-safe",
    "utility",
    "vanilla"
  ],
  "repository": "jack3898/jwtools.git",
  "types": "./dist/core.d.ts"
}
